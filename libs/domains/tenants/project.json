{
  "name": "tenants",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/domains/tenants",
  "projectType": "library",
  "tags": ["type:domain-package", "domain:tenants", "publishable"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/libs/domains/tenants/domain/dist"],
      "dependsOn": ["tenants-domain:build"],
      "options": {
        "command": "echo 'tenants package build complete'"
      }
    },
    "nx-release-publish": {
      "options": {
        "packageRoot": "libs/domains/tenants"
      }
    }
  }
}
