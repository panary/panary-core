{
  "name": "data-access",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/shared/data-access/src",
  "prefix": "lib",
  "projectType": "library",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/angular:package",
      "outputs": [
        "{workspaceRoot}/libs/shared/data-access/dist"
      ],
      "dependsOn": [
        "build-server",
        "^build"
      ],
      "options": {
        "project": "libs/shared/data-access/ng-package.json",
        "tsConfig": "libs/shared/data-access/tsconfig.lib.json"
      }
    },
    "build-server": {
      "executor": "@nx/js:tsc",
      "outputs": [
        "{projectRoot}/dist-server"
      ],
      "dependsOn": [
        "^build"
      ],
      "options": {
        "outputPath": "libs/shared/data-access/dist-server",
        "main": "libs/shared/data-access/src/server.ts",
        "tsConfig": "libs/shared/data-access/tsconfig.server.json",
        "assets": []
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    }
  },
  "implicitDependencies": [
    "businessdays-domain",
    "common",
    "shared-data-access-config",
    "shared-ui-notifications",
    "shared-util-error-handling",
    "shared-util-helpers",
    "user-preferences-data-access"
  ]
}
