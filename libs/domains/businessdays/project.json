        "{workspaceRoot}/libs/domains/businessdays/domain/dist"
      ],
      "dependsOn": [
        "businessdays-domain:build"
      ],
      "options": {
        "command": "echo 'businessdays package build complete'"
      }
    },
    "nx-release-publish": {
      "options": {
        "packageRoot": "libs/domains/businessdays"
      }
    }
  }
}
