{
  "host": "0.0.0.0",
  "port": 3030,
  "origins": [
    "http://localhost:3030",
    "http://localhost:4200",
    "http://localhost:4201",
    "http://localhost:4202",
    "https://tauri.localhost",
    "tauri://localhost"
  ],
  "system": {
    "mode": "standalone",
    "dbType": "sqlite"
  },
  "paginate": {
    "default": 50,
    "max": 250
  },
  "sqlite": {
    "client": "better-sqlite3",
    "connection": {
      "filename": "data/api-edge.sqlite"
    },
    "useNullAsDefault": true
  },
  "authentication": {
    "entity": "user",
    "service": "users",
    "secret": "CHANGE_ME_IN_PRODUCTION",
    "authStrategies": [
      "jwt",
      "local"
    ],
    "jwtOptions": {
      "header": {
        "typ": "access"
      },
      "audience": "https://panary.io",
      "issuer": "feathers",
      "algorithm": "HS256",
      "expiresIn": "1d"
    },
    "local": {
      "usernameField": "loginname",
      "passwordField": "password"
    }
  },
  "logLevel": "debug",
  "auditCleanup": {
    "enabled": true,
    "retentionDays": 90,
    "hour": 2,
    "minuteJitterMs": 300000,
    "cloudReachableMaxAgeDays": 7,
    "batchSize": 1000
  }
}
