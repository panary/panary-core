      "@panary-core/shared/data-access": ["libs/shared/data-access/src/index.ts"],
      "@panary-core/apikeys/domain": ["libs/domains/apikeys/domain/src/index.ts"],
      "@panary-core/customers/domain": ["libs/domains/customers/domain/src/index.ts"],
