{
  "name": "suppliers",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/domains/suppliers",
  "projectType": "library",
  "tags": ["type:domain-package", "domain:suppliers", "publishable"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/libs/domains/suppliers/domain/dist"],
      "dependsOn": ["suppliers-domain:build"],
      "options": {
        "command": "echo 'suppliers package build complete'"
      }
    },
    "nx-release-publish": {
      "options": {
        "packageRoot": "libs/domains/suppliers"
      }
    }
  }
}
