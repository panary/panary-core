{
  "name": "pricelists",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/domains/pricelists",
  "projectType": "library",
  "tags": ["type:domain-package", "domain:pricelists", "publishable"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/libs/domains/pricelists/domain/dist"],
      "dependsOn": ["pricelists-domain:build"],
      "options": {
        "command": "echo 'pricelists package build complete'"
      }
    },
    "nx-release-publish": {
      "options": {
        "packageRoot": "libs/domains/pricelists"
      }
    }
  }
}
