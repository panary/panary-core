{
  "name": "businessdays",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/domains/businessdays",
  "projectType": "library",
  "tags": [
    "type:domain-package",
    "domain:businessdays",
    "publishable"
  ],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
