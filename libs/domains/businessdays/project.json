{
  "name": "businessdays",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/domains/businessdays",
  "projectType": "library",
  "tags": ["type:domain-package", "domain:businessdays", "publishable"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": [
        "{workspaceRoot}/libs/domains/businessdays/domain/dist",
        "{workspaceRoot}/libs/domains/businessdays/aggregator/dist"
      ],
      "dependsOn": ["businessdays-domain:build", "businessdays-aggregator:build"],
      "options": {
        "command": "echo 'businessdays package build complete'"
      }
    },
    "nx-release-publish": {
      "options": {
        "packageRoot": "libs/domains/businessdays"
      }
    }
  }
}
