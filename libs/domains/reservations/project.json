{
  "name": "reservations",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/domains/reservations",
  "projectType": "library",
  "tags": ["type:domain-package", "domain:reservations", "publishable"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/libs/domains/reservations/domain/dist"],
      "dependsOn": ["reservations-domain:build"],
      "options": {
        "command": "echo 'reservations package build complete'"
      }
    },
    "nx-release-publish": {
      "options": {
        "packageRoot": "libs/domains/reservations"
      }
    }
  }
}
