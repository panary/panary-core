{
  "name": "customers",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/domains/customers",
  "projectType": "library",
  "tags": [
    "type:domain-package",
    "domain:customers",
    "publishable"
  ],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": [
        "{workspaceRoot}/libs/domains/customers/domain/dist"
      ],
      "dependsOn": [
        "customers-domain:build"
      ],
      "options": {
        "command": "echo 'customers package build complete'"
      }
    },
    "nx-release-publish": {
      "options": {
        "packageRoot": "libs/domains/customers"
      }
    }
  }
}
