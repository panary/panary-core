{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-utils/schema.json",
  "productName": "Panary — Terminal",
  "version": "26.6.1",
  "identifier": "de.panary.pos",
  "build": {
    "frontendDist": "../../../dist/apps/pos-client/browser",
    "devUrl": "http://localhost:4200",
    "beforeDevCommand": "pnpm nx serve pos-client",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Panary — Terminal",
        "width": 1280,
        "height": 800,
        "fullscreen": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self' 'unsafe-inline' 'unsafe-eval' data: blob:; connect-src 'self' http://*:3030 ws://*:3030 wss://*:3030 https://tauri.localhost tauri://localhost https://github.com https://*.github.com https://*.githubusercontent.com; img-src 'self' data: blob: https://tauri.localhost; font-src 'self' data: https://tauri.localhost; style-src 'self' 'unsafe-inline'"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/panary/panary-core/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEFFNjZBRjQ4RjhDODA2QkMKUldTOEJzajRTSzltcnVyOWhEQTFYakJ0OHViRmJ5azdneld4Mk55cWpPK29MaTN6KzE4cjdHbGwK"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis",
      "deb",
      "appimage"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "perMachine",
        "languages": [
          "German"
        ],
        "displayLanguageSelector": false
      }
    }
  }
}
