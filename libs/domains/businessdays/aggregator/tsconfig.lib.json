{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../../../dist/out-tsc",
    "declaration": true,
    "types": ["node"],
    "moduleResolution": "node",
    "module": "commonjs",
    "paths": {
      "@panary/orders/domain": ["libs/domains/orders/domain/dist/index.d.ts"],
      "@panary/write-offs/domain": ["libs/domains/write-offs/domain/dist/index.d.ts"],
      "@panary/working-times/domain": ["libs/domains/working-times/domain/dist/index.d.ts"],
      "@panary/ingredients/domain": ["libs/domains/ingredients/domain/dist/index.d.ts"],
      "@panary/recipes/domain": ["libs/domains/recipes/domain/dist/index.d.ts"],
      "@panary/products/domain": ["libs/domains/products/domain/dist/index.d.ts"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "vite.config.ts",
    "vite.config.mts",
    "vitest.config.ts",
    "vitest.config.mts",
    "src/**/*.test.ts",
    "src/**/*.spec.ts"
  ]
}
