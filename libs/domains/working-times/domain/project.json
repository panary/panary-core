{
  "name": "working-times-domain",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/domains/working-times/domain/src",
  "projectType": "library",
  "tags": [
    "type:domain",
    "domain:working-times"
  ],
  "targets": {
    "build": {
      "executor": "@nx/rollup:rollup",
      "outputs": [
        "{workspaceRoot}/libs/domains/working-times/domain/dist"
      ],
      "options": {
        "outputPath": "libs/domains/working-times/domain/dist",
        "project": "libs/domains/working-times/package.json",
        "tsConfig": "libs/domains/working-times/domain/tsconfig.lib.json",
        "main": "libs/domains/working-times/domain/src/index.ts",
        "format": [
          "cjs"
        ],
        "external": [
          "@feathersjs/feathers",
          "@feathersjs/typebox",
          "@sinclair/typebox"
        ],
        "generatePackageJson": false,
        "compiler": "tsc"
      }
    }
  }
}
