  "scripts": {
    "dev": "pnpm nx run-many --target=build --projects=tag:type:domain && pnpm nx run-many --target=serve --projects=pos-client,api-edge --parallel",
    "start": "nx serve pos-client",
    "db:migrate": "TS_NODE_PROJECT=apps/api-edge/tsconfig.migrations.json knex --knexfile apps/api-edge/knexfile.ts migrate:latest",
    "db:create": "TS_NODE_PROJECT=apps/api-edge/tsconfig.migrations.json knex --knexfile apps/api-edge/knexfile.ts migrate:make",
    "tauri:dev": "cd apps/pos-client && tauri dev",
    "tauri:build": "cd apps/pos-client && tauri build",
    "admin:dev": "nx serve admin-client",
    "admin:build": "nx build admin-client --configuration=production",
    "version:bump": "node tools/scripts/bump-version.mjs",
    "docker:build": "bash tools/docker/build-edge.sh",
    "docker:release": "bash tools/docker/build-edge.sh --push",
    "release": "bash tools/scripts/release-tag.sh --push",
    "release:edge": "bash tools/scripts/release-tag.sh --type edge --push",
    "release:pos-client": "bash tools/scripts/release-tag.sh --type pos-client --push",
    "security:install": "bash scripts/install-security-tools.sh",
    "security:scan": "node scripts/security-scan.mjs --mode=local",
    "security:report": "node scripts/security-scan.mjs --mode=all --report",
    "prepare": "lefthook install || true"
  },
  "private": true,
  "engines": {
    "node": ">=22.0.0"
  },
