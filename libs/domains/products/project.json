{
  "name": "products",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/domains/products",
  "projectType": "library",
  "tags": [
    "type:domain-package",
    "domain:products",
    "publishable"
  ],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": [
        "{workspaceRoot}/libs/domains/products/domain/dist"
      ],
      "dependsOn": [
        "products-domain:build"
      ],
      "options": {
        "command": "echo 'products package build complete'"
      }
    },
    "nx-release-publish": {
      "options": {
        "packageRoot": "libs/domains/products"
      }
    }
  }
}
