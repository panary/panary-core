{
  "name": "users",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/domains/users",
  "projectType": "library",
  "tags": [
    "type:domain-package",
    "domain:users",
    "publishable"
  ],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": [
        "{workspaceRoot}/libs/domains/users/domain/dist",
        "{workspaceRoot}/libs/domains/users/data-access/dist"
      ],
      "dependsOn": [
        "users-domain:build",
        "users-data-access:build"
      ],
      "options": {
        "command": "echo 'users package build complete'"
      }
    },
    "nx-release-publish": {
      "options": {
        "packageRoot": "libs/domains/users"
      }
    }
  }
}
